#!/bin/bash

REPO="$HOME/cheat/cli"

if [[ -n $2 && -e "$REPO/$1/$2.txt" ]]; then
    vim "$REPO/$1/$2.txt"
elif [[ -n $1 && -z $2 && -e "$REPO/$1.txt" ]]; then
    vim "$REPO/$1.txt"
else
    file=$(
        find "$REPO" -type f -not -path "*/.git/*" |
        sed "s|$REPO/||" |
        sed 's|\.txt$||' |
        fzf --preview "cat $REPO/{}.txt" --preview-window=right:70%:wrap
    )

    [[ -n $file ]] && vim "$REPO/$file.txt"
fi
